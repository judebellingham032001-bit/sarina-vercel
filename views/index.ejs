<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">

<title>SARINA STORE | OPERASIONAL</title>

<link rel="icon" type="image/png" href="/logo.png?v=1.6">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

body{
    background:#f1f5f9;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding-bottom:30px;
    font-size:.82rem;
}

.container{
    max-width:900px;
    padding:6px;
}

/* NAVIGATION */
.nav-custom{
    background:white;
    border-radius:50px;
    padding:3px;
    border:1px solid #e2e8f0;
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    width:100%;
    justify-content:center;
    gap:2px;
}

.nav-custom::-webkit-scrollbar{
    display:none;
}

.nav-link{
    border-radius:50px;
    color:#64748b;
    font-weight:700;
    padding:5px 9px;
    font-size:.58rem;
    border:none;
    white-space:nowrap;
    flex-shrink:0;
}

.nav-link.active{
    background:#2563eb !important;
    color:white !important;
}

/* CARD */
.card-main{
    background:white;
    border-radius:12px;
    box-shadow:0 1px 3px rgba(0,0,0,.05);
    margin-bottom:12px;
    overflow:hidden;
}

.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* STOK COLOR */
.stok-merah{
    background-color:#fee2e2 !important;
    color:#dc2626 !important;
    font-weight:800;
}

.stok-kuning{
    background-color:#fef3c7 !important;
    color:#d97706 !important;
    font-weight:800;
}

.stok-kuning-keras{
    background-color:#fde68a !important;
    color:#92400e !important;
    font-weight:800;
}

.stok-ijo{
    background-color:#dcfce7 !important;
    color:#16a34a !important;
    font-weight:800;
}

/* TABLE HEAD */
.head-stok th{
    background:#003153 !important;
    color:white !important;
}

.head-ship th{
    background:#000 !important;
    color:white !important;
}

.head-kas-dark th{
    background:#cbd5e1 !important;
    color:#1e293b !important;
}

/* FREEZE HEADER PACKAGING */
/* 1. Bungkus tabel dengan container ini di HTML (Lihat langkah ke-2) */
.table-container {
    max-height: 500px; /* Atur tinggi tabel agar bisa di-scroll */
    overflow: auto;
    position: relative;
}

/* 2. Freeze Header (Atas) */
.head-pack th {
    background: #003153 !important; /* Wajib ada background */
    color: white !important;
    position: sticky;
    top: 0;
    z-index: 20; /* Lapisan 20 */
}

/* 3. Freeze Kolom Produk (Kiri) */
#packaging table td:first-child, 
#packaging table th:first-child {
    position: sticky;
    left: 0;
    z-index: 10; /* Lapisan 10 */
    background: white; /* Wajib ada background agar tidak transparan */
    border-right: 1px solid #dee2e6;
}

/* 4. Pojok Kiri Atas (Pertemuan Header & Kolom Pertama) */
#packaging table thead th:first-child {
    z-index: 30; /* Paling tinggi agar menutupi semuanya */
    background: #003153 !important;
}

/* SALDO */
.bg-normal{
    background:linear-gradient(135deg,#1e293b,#475569);
}

.bg-minus{
    background:#dc2626 !important;
}

/* TABLE */
th{
    font-size:.55rem;
    padding:8px !important;
    text-transform:uppercase;
    white-space:nowrap;
}

td{
    padding:7px !important;
    vertical-align:middle;
    font-size:.62rem;
}

/* BADGE */
.badge-status{
    padding:3px 7px;
    border-radius:50px;
    font-size:.5rem;
    font-weight:800;
    display:inline-block;
}

.bg-out{
    background:#fee2e2;
    color:#dc2626;
}

.bg-low{
    background:#fef3c7;
    color:#d97706;
}

.bg-tersedia{
    background:#dcfce7;
    color:#16a34a;
}

/* TEXT */
.text-debet{
    color:#dc2626;
    font-weight:800;
}

.text-kredit{
    color:#16a34a;
    font-weight:800;
}

/* BUTTON */
.btn-bukti{
    background:#2563eb;
    color:white;
    font-size:.5rem;
    font-weight:800;
    padding:4px 6px;
    border-radius:4px;
    text-decoration:none;
}

.filter-box{
    background:#f8fafc;
    padding:10px;
    border-radius:10px;
    margin:10px;
    border:1px solid #e2e8f0;
}

.btn-toggle{
    font-size:.6rem;
    font-weight:700;
    color:#2563eb;
    background:none;
    border:none;
    margin:5px 10px;
    text-decoration:underline;
}

/* LOGO */
.logo-sarina{
    width:65px;
    height:auto;
    margin-bottom:5px;
}

h1{
    font-size:1.2rem !important;
    font-weight:800;
    margin:0;
}

.sub-title{
    font-size:.55rem;
    color:#64748b;
    font-weight:600;
    letter-spacing:1px;
}

/* MOBILE */
@media(max-width:576px){

    body{
        font-size:.75rem;
    }

    td{
        font-size:.58rem;
        padding:6px !important;
    }

    th{
        font-size:.5rem;
        padding:6px !important;
    }

    .nav-link{
        font-size:.52rem;
        padding:4px 7px;
    }

    .logo-sarina{
        width:55px;
    }

    h1{
        font-size:1rem !important;
    }

}

</style>
</head>

<body>

<div class="container">

    <div class="text-center py-3">

        <img src="/logo.png"
             alt="Logo Sarina"
             class="logo-sarina">

        <h1>SARINA STORE</h1>

        <p class="sub-title">
            MANAJEMEN OPERASIONAL
        </p>

        <ul class="nav nav-pills nav-custom mt-2">

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('stocks', this)">
                    STOK PRODUK
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('shipping', this)">
                    PENGIRIMAN
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('kas', this)">
                    KAS
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link active"
                    onclick="openMenu('packaging', this)">
                    STOK KEMASAN
                </button>
            </li>

        </ul>

    </div>

    <!-- STOCK -->
    <div id="stocks" class="content-section">

        <div class="text-center mb-3">
            <small class="text-muted fw-bold">
                LAST UPDATED:
                <%= lastUpdate %>
            </small>
        </div>

        <div class="card-main">

            <table class="table table-sm mb-0">

                <thead class="head-stok">

                    <tr>

                        <th class="ps-3">
                            PRODUK
                        </th>

                        <th class="text-center">
                            QTY
                        </th>

                        <th class="text-end pe-3">
                            STATUS
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <% if (typeof stocks !== 'undefined' && stocks) {
                        stocks.forEach(s => { %>

                    <tr class="border-bottom">

                        <td class="ps-3 fw-bold text-uppercase">
                            <%= s.nama %>
                        </td>

                        <td class="text-center fw-bold">
                            <%= s.display %>
                        </td>

                        <td class="text-end pe-3">

                            <% if(s.statusTxt === 'OUT OF STOCK') { %>

                                <span class="badge-status bg-out">
                                    HABIS
                                </span>

                            <% } else if(s.statusTxt === 'LOW') { %>

                                <span class="badge-status bg-low">
                                    LOW
                                </span>

                            <% } else { %>

                                <span class="badge-status bg-tersedia">
                                    READY
                                </span>

                            <% } %>

                        </td>

                    </tr>

                    <% })} %>

                </tbody>

            </table>

        </div>

    </div>

    <!-- SHIPPING -->
    <div id="shipping" class="content-section">

        <div class="card-main">

            <button class="btn-toggle"
                onclick="toggleFull('tableShip', this)">

                + FILTER & LIHAT SEMUA

            </button>

            <div id="filterShip" style="display:none;">

                <div class="filter-box">

                    <div class="row g-2">

                        <div class="col-6">

                            <select id="sM"
                                class="form-select form-select-sm"
                                onchange="filterData('tableShip', 'sM', 'sY')">

                                <option value="">Bulan</option>
                                <option value="Jan">Jan</option>
                                <option value="Feb">Feb</option>

                            </select>

                        </div>

                        <div class="col-6">

                            <select id="sY"
                                class="form-select form-select-sm"
                                onchange="filterData('tableShip', 'sM', 'sY')">

                                <option value="">Tahun</option>
                                <option value="2025">2025</option>
                                <option value="2026">2026</option>

                            </select>

                        </div>

                    </div>

                </div>

            </div>

            <div class="table-responsive">

                <table class="table table-sm text-center mb-0"
                    id="tableShip">

                    <thead class="head-ship">

                        <tr>

                            <th class="ps-3 text-start">
                                Tanggal
                            </th>

                            <th>SPX</th>
                            <th>JNE</th>
                            <th>J&T</th>
                            <th>Sameday/Instant</th>
                            <th>TOTAL</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if (typeof shippingAll !== 'undefined' && shippingAll) {
                            shippingAll.forEach((k, i) => { %>

                        <tr class="row-data border-bottom"
                            data-index="<%= i %>">

                            <td class="text-start fw-bold ps-3">
                                <%= k.tgl %>
                            </td>

                            <td><%= k.spx %></td>
                            <td><%= k.jne %></td>
                            <td><%= k.jnt %></td>
                            <td><%= k.sd %></td>

                            <td class="fw-bold text-primary">
                                <%= k.tot %>
                            </td>

                        </tr>

                        <% })} %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- KAS -->
    <div id="kas" class="content-section">

        <div class="card-main">

            <div class="p-4 text-center <%= (typeof isSaldoMinus !== 'undefined' && isSaldoMinus) ? 'bg-minus' : 'bg-normal' %>"
                style="color:white;">

                <small class="fw-bold opacity-75">
                    SALDO KAS
                </small>

                <h2 class="fw-bold m-0"
                    style="font-size:1.3rem;">

                    <%= typeof saldoTotal !== 'undefined' ? saldoTotal : 'Rp 0' %>

                </h2>

            </div>

            <button class="btn-toggle"
                onclick="toggleFull('tableKas', this)">

                + FILTER & LIHAT SEMUA

            </button>

            <div class="table-responsive">

                <table class="table table-sm mb-0"
                    id="tableKas">

                    <thead class="head-kas-dark">

                        <tr>

                            <th>Tanggal</th>
                            <th>Keterangan</th>
                            <th class="text-end">Mutasi</th>
                            <th class="text-center">Bukti</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if (typeof kasAll !== 'undefined' && kasAll) {
                            kasAll.forEach((t, i) => { %>

                        <tr class="row-data border-bottom"
                            data-index="<%= i %>">

                            <td>
                                <%= t.tgl %>
                            </td>

                            <td>

                                <div class="fw-bold text-uppercase">
                                    <%= t.kat %>
                                </div>

                                <div class="text-muted"
                                    style="font-size:.52rem;">

                                    <%= t.ket %>

                                </div>

                            </td>

                            <td class="text-end">

                                <div class="<%= t.tipeMutasi === 'debet' ? 'text-debet' : 'text-kredit' %>">

                                    <%= t.mutasi %>

                                </div>

                                <div style="font-size:.5rem;">

                                    Sisa:
                                    <%= t.saldo %>

                                </div>

                            </td>

                            <td class="text-center">

                                <% if(t.bukti) { %>

                                <a href="<%= t.bukti %>"
                                    target="_blank"
                                    class="btn-bukti">

                                    LIHAT BUKTI

                                </a>

                                <% } else { %>

                                -

                                <% } %>

                            </td>

                        </tr>

                        <% })} %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

<div id="packaging" class="content-section active">

    <div class="text-center mb-3">
        <small class="text-muted fw-bold">
            LAST UPDATED: <%= typeof lastUpdatePack !== 'undefined' ? lastUpdatePack : '-' %>
        </small>
    </div>

    <div class="card-main">
        <div class="table-container">
            <table class="table table-bordered table-sm text-center mb-0">
                <thead class="head-pack">
                    <tr>
                        <th class="ps-3 text-start">PRODUCT</th>
                        <% if (typeof packHeaders !== 'undefined') {
                            packHeaders.forEach(h => { %>
                        <th><%= h %></th>
                        <% }) } %>
                    </tr>
                </thead>
                <tbody style="font-size:.65rem;">
<% if (typeof packagingAll !== 'undefined' && packagingAll) { 
    packagingAll.forEach(p => { %>
        <tr class="border-bottom">
            <td class="ps-3 text-start fw-bold text-uppercase text-secondary">
                <%= p.nama %>
            </td>
            <% p.listVarian.forEach(val => {
                let kelas = 'stok-netral'; 
                let strVal = val ? val.toString().trim() : '-';

                // Logika hanya jika bukan strip/kosong
                if (strVal !== '-' && strVal !== '') {
                    // Hapus karakter non-angka kecuali titik
                    let cleanVal = strVal.replace(/[^0-9.]/g, ''); 
                    let angka = parseFloat(cleanVal);

                    if (!isNaN(angka)) {
                        if (angka === 0) {
                            kelas = 'stok-merah';
                        } else if (angka <= 2.5) {
                            kelas = 'stok-merah';
                        } else if (angka <= 3) {
                            kelas = 'stok-kuning';
                        } else {
                            kelas = 'stok-ijo';
                        }
                    }
                }
            %>
            <td class="<%= kelas %>"><%= val %></td>
            <% }) %>
        </tr>
    <% }); 
} %>
                </tbody>
            </table>
        </div> </div>

</div>
<script>

function openMenu(id, el){

    document.querySelectorAll('.content-section')
        .forEach(s => s.classList.remove('active'));

    document.querySelectorAll('.nav-link')
        .forEach(l => l.classList.remove('active'));

    document.getElementById(id)
        .classList.add('active');

    el.classList.add('active');
}

function toggleFull(tableId, btn){

    const rows = document.querySelectorAll(
        `#${tableId} .row-data`
    );

    const hidden =
        rows[0].style.display === "none";

    if(hidden){

        rows.forEach(r => r.style.display = "");

        btn.innerText = "- SEMBUNYIKAN";

    } else {

        showDefault(tableId);

        btn.innerText =
            "+ FILTER & LIHAT SEMUA";
    }
}

function showDefault(t){

    const r =
        document.querySelectorAll(`#${t} .row-data`);

    r.forEach((x, i) => {

        x.style.display =
            (i < r.length - 10)
            ? "none"
            : "";
    });
}

window.onload = () => {

    showDefault('tableShip');

    showDefault('tableKas');
}

</script>

</body>
</html>
