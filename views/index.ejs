<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">

<title>SARINA STORE | OPERASIONAL</title>

<link rel="icon" type="image/png" href="/logo.png?v=1.6">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

body{
    background:#f1f5f9;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding-bottom:30px;
    font-size:.82rem;
}

.container{
    max-width:900px;
    padding:6px;
}

/* NAVIGATION */
.nav-custom{
    background:white;
    border-radius:50px;
    padding:3px;
    border:1px solid #e2e8f0;
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    width:100%;
    justify-content:center;
    gap:2px;
}

.nav-custom::-webkit-scrollbar{
    display:none;
}

.nav-link{
    border-radius:50px;
    color:#64748b;
    font-weight:700;
    padding:5px 9px;
    font-size:.58rem;
    border:none;
    white-space:nowrap;
    flex-shrink:0;
}

.nav-link.active{
    background:#2563eb !important;
    color:white !important;
}

/* CARD */
.card-main{
    background:white;
    border-radius:12px;
    box-shadow:0 1px 3px rgba(0,0,0,.05);
    margin-bottom:12px;
    overflow:hidden;
}

.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* STOK COLOR */
.stok-merah{
    background-color:#fee2e2 !important;
    color:#dc2626 !important;
    font-weight:800;
}

.stok-kuning{
    background-color:#fef3c7 !important;
    color:#d97706 !important;
    font-weight:800;
}

.stok-kuning-keras{
    background-color:#fde68a !important;
    color:#92400e !important;
    font-weight:800;
}

.stok-ijo{
    background-color:#dcfce7 !important;
    color:#16a34a !important;
    font-weight:800;
}

/* TABLE HEAD */
.head-stok th{
    background:#003153 !important;
    color:white !important;
}

.head-ship th{
    background:#000 !important;
    color:white !important;
}

.head-kas-dark th{
    background:#cbd5e1 !important;
    color:#1e293b !important;
}

/* =========================================
   FREEZE HEADER PACKAGING
========================================= */

.table-container{
    max-height:500px;
    overflow:auto;
    position:relative;
}

/* HEADER */
.head-pack th{
    background:#003153 !important;
    color:white !important;
    position:sticky;
    top:0;
    z-index:20;
}

/* HEADER GRAMASI HIJAU */
.head-pack th:not(:first-child){
    background:#166534 !important;
    color:white !important;
}

/* HEADER PRODUCT TETAP BIRU */
.head-pack th:first-child{
    background:#003153 !important;
    color:white !important;
}

/* FREEZE KOLOM PRODUCT */
#packaging table td:first-child,
#packaging table th:first-child{
    position:sticky;
    left:0;
    z-index:10;
    border-right:1px solid #dee2e6;
}

/* PRODUCT COLUMN SELANG SELING SAMAR */
#packaging tbody tr:nth-child(odd) td:first-child{
    background:#f8fafc !important;
}

#packaging tbody tr:nth-child(even) td:first-child{
    background:#eef2f7 !important;
}

/* BIAR GAK KETIMPA */
#packaging table thead th:first-child{
    z-index:30;
}

/* HOVER TABLE */
#packaging tbody tr:hover td{
    background:#f1f5f9;
    transition:.15s;
}

/* TAPI PRODUCT TETAP KELIHATAN */
#packaging tbody tr:hover td:first-child{
    background:#dbeafe !important;
}

/* SALDO */
.bg-normal{
    background:linear-gradient(135deg,#1e293b,#475569);
}

.bg-minus{
    background:#dc2626 !important;
}

/* TABLE */
th{
    font-size:.55rem;
    padding:8px !important;
    text-transform:uppercase;
    white-space:nowrap;
}

td{
    padding:7px !important;
    vertical-align:middle;
    font-size:.62rem;
}

/* BADGE */
.badge-status{
    padding:3px 7px;
    border-radius:50px;
    font-size:.5rem;
    font-weight:800;
    display:inline-block;
}

.bg-out{
    background:#fee2e2;
    color:#dc2626;
}

.bg-low{
    background:#fef3c7;
    color:#d97706;
}

.bg-tersedia{
    background:#dcfce7;
    color:#16a34a;
}
/* HOVER STOK PRODUK */
#stocks tbody tr{
    transition:.15s;
    cursor:pointer;
}

#stocks tbody tr:hover td{
    background:#eff6ff !important;
}

/* EFEK SENTUH HP */
#stocks tbody tr:active td{
    background:#dbeafe !important;
}

/* TEXT */
.text-debet{
    color:#dc2626;
    font-weight:800;
}

.text-kredit{
    color:#16a34a;
    font-weight:800;
}

/* BUTTON */
.btn-bukti{
    background:#2563eb;
    color:white;
    font-size:.5rem;
    font-weight:800;
    padding:4px 6px;
    border-radius:4px;
    text-decoration:none;
}

.filter-box{
    background:#f8fafc;
    padding:10px;
    border-radius:10px;
    margin:10px;
    border:1px solid #e2e8f0;
}

.btn-toggle{
    font-size:.6rem;
    font-weight:700;
    color:#2563eb;
    background:none;
    border:none;
    margin:5px 10px;
    text-decoration:underline;
}

/* LOGO */
.logo-sarina{
    width:65px;
    height:auto;
    margin-bottom:5px;
}

h1{
    font-size:1.2rem !important;
    font-weight:800;
    margin:0;
}

.sub-title{
    font-size:.55rem;
    color:#64748b;
    font-weight:600;
    letter-spacing:1px;
}

/* MOBILE */
@media(max-width:576px){

    body{
        font-size:.75rem;
    }

    td{
        font-size:.58rem;
        padding:6px !important;
    }

    th{
        font-size:.5rem;
        padding:6px !important;
    }

    .nav-link{
        font-size:.52rem;
        padding:4px 7px;
    }

    .logo-sarina{
        width:55px;
    }

    h1{
        font-size:1rem !important;
    }

}

</style>
</head>

<body>

<div class="container">

    <div class="text-center py-3">

        <img src="/logo.png"
             alt="Logo Sarina"
             class="logo-sarina">

        <h1>SARINA STORE</h1>

        <p class="sub-title">
            MANAJEMEN OPERASIONAL
        </p>

        <ul class="nav nav-pills nav-custom mt-2">

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('stocks', this)">
                    STOK PRODUK
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('shipping', this)">
                    PENGIRIMAN
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('kas', this)">
                    KAS
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link active"
                    onclick="openMenu('packaging', this)">
                    STOK KEMASAN
                </button>
            </li>

        </ul>

    </div>

    <!-- STOCK -->
    <div id="stocks" class="content-section">

        <div class="text-center mb-3">
            <small class="text-muted fw-bold">
                Last Updated:
                <%= lastUpdate %>
            </small>
        </div>

        <div class="card-main">

            <table class="table table-sm mb-0">

                <thead class="head-stok">

                    <tr>

                        <th class="ps-3">
                            PRODUK
                        </th>

                        <th class="text-center">
                            QTY
                        </th>

                        <th class="text-end pe-3">
                            STATUS
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <% if (typeof stocks !== 'undefined' && stocks) {
                        stocks.forEach(s => { %>

                    <tr class="border-bottom">

                        <td class="ps-3 fw-bold text-uppercase">
                            <%= s.nama %>
                        </td>

                        <td class="text-center fw-bold">
                            <%= s.display %>
                        </td>

<td class="text-end pe-3">

<%
    let rawQty = s.display ? s.display.toString().trim() : "0";

    // convert pecahan unicode
    let qtyFix = rawQty
        .replace(/½/g, '.5')
        .replace(/¼/g, '.25')
        .replace(/¾/g, '.75');

    // ambil angka
    qtyFix = qtyFix.replace(/[^0-9.]/g, '');

    let qtyNum = parseFloat(qtyFix);

    if(isNaN(qtyNum)) qtyNum = 0;
%>

<% if(qtyNum <= 0){ %>

    <span class="badge-status bg-out">
        HABIS
    </span>

<% } else if(qtyNum <= 2.5){ %>

    <span class="badge-status bg-low">
        LOW
    </span>

<% } else { %>

    <span class="badge-status bg-tersedia">
        READY
    </span>

<% } %>

</td>

                    </tr>

                    <% })} %>

                </tbody>

            </table>

        </div>

    </div>

    <!-- SHIPPING -->
    <div id="shipping" class="content-section">

        <div class="card-main">

            <button class="btn-toggle"
                onclick="toggleFull('tableShip', this)">

                + FILTER & LIHAT SEMUA

            </button>

            <div id="filterShip" style="display:none;">

                <div class="filter-box">

                    <div class="row g-2">

                        <div class="col-6">

                            <select id="sM"
                                class="form-select form-select-sm"
                                onchange="filterData('tableShip', 'sM', 'sY')">

<option value="">Bulan</option>
<option value="Jan">Jan</option>
<option value="Feb">Feb</option>
<option value="Mar">Mar</option>
<option value="Apr">Apr</option>
<option value="Mei">Mei</option>
<option value="Jun">Jun</option>
<option value="Jul">Jul</option>
<option value="Agu">Agu</option>
<option value="Sep">Sep</option>
<option value="Okt">Okt</option>
<option value="Nov">Nov</option>
<option value="Des">Des</option>

                            </select>

                        </div>

                        <div class="col-6">

                            <select id="sY"
                                class="form-select form-select-sm"
                                onchange="filterData('tableShip', 'sM', 'sY')">

<option value="">Tahun</option>
<option value="2025">2025</option>
<option value="2026">2026</option>
<option value="2027">2027</option>
<option value="2028">2028</option>
<option value="2029">2029</option>
<option value="2030">2030</option>
<option value="2031">2031</option>
<option value="2032">2032</option>
<option value="2033">2033</option>
<option value="2034">2034</option>
<option value="2035">2035</option>

                            </select>

                        </div>

                    </div>

                </div>

            </div>

            <div class="table-responsive">

                <table class="table table-sm text-center mb-0"
                    id="tableShip">

                    <thead class="head-ship">

                        <tr>

                            <th class="ps-3 text-start">
                                Tanggal
                            </th>

                            <th>SPX</th>
                            <th>JNE</th>
                            <th>J&T</th>
                            <th>Sameday/Instant</th>
                            <th>TOTAL</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if (typeof shippingAll !== 'undefined' && shippingAll) {
                            shippingAll.forEach((k, i) => { %>

                        <tr class="row-data border-bottom"
                            data-index="<%= i %>">

                            <td class="text-start fw-bold ps-3">
                                <%= k.tgl %>
                            </td>

                            <td><%= k.spx %></td>
                            <td><%= k.jne %></td>
                            <td><%= k.jnt %></td>
                            <td><%= k.sd %></td>

                            <td class="fw-bold text-primary">
                                <%= k.tot %>
                            </td>

                        </tr>

                        <% })} %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- KAS -->
    <div id="kas" class="content-section">

        <div class="card-main">

            <div class="p-4 text-center <%= (typeof isSaldoMinus !== 'undefined' && isSaldoMinus) ? 'bg-minus' : 'bg-normal' %>"
                style="color:white;">

                <small class="fw-bold opacity-75">
                    SALDO KAS
                </small>

                <h2 class="fw-bold m-0"
                    style="font-size:1.3rem;">

                    <%= typeof saldoTotal !== 'undefined' ? saldoTotal : 'Rp 0' %>

                </h2>

            </div>

            <button class="btn-toggle"
                onclick="toggleFull('tableKas', this)">

                + FILTER & LIHAT SEMUA

            </button>
<div id="filterKas" style="display:none;">

    <div class="filter-box">

        <div class="row g-2">

            <div class="col-6">

                <select id="kM"
                    class="form-select form-select-sm"
                    onchange="filterData('tableKas', 'kM', 'kY')">

                    <option value="">Bulan</option>

                    <option value="Jan">Jan</option>
                    <option value="Feb">Feb</option>
                    <option value="Mar">Mar</option>
                    <option value="Apr">Apr</option>
                    <option value="Mei">Mei</option>
                    <option value="Jun">Jun</option>
                    <option value="Jul">Jul</option>
                    <option value="Agu">Agu</option>
                    <option value="Sep">Sep</option>
                    <option value="Okt">Okt</option>
                    <option value="Nov">Nov</option>
                    <option value="Des">Des</option>

                </select>

            </div>

            <div class="col-6">

                <select id="kY"
                    class="form-select form-select-sm"
                    onchange="filterData('tableKas', 'kM', 'kY')">

                    <option value="">Tahun</option>

                    <option value="2025">2025</option>
                    <option value="2026">2026</option>
                    <option value="2027">2027</option>
                    <option value="2028">2028</option>
                    <option value="2029">2029</option>
                    <option value="2030">2030</option>
                    <option value="2031">2031</option>
                    <option value="2032">2032</option>
                    <option value="2033">2033</option>
                    <option value="2034">2034</option>
                    <option value="2035">2035</option>

                </select>

            </div>

        </div>

    </div>

</div>

            <div class="table-responsive">

                <table class="table table-sm mb-0"
                    id="tableKas">

                    <thead class="head-kas-dark">

                        <tr>

                            <th>Tanggal</th>
                            <th>Keterangan</th>
                            <th class="text-end">Mutasi</th>
                            <th class="text-center">Bukti</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if (typeof kasAll !== 'undefined' && kasAll) {
                            kasAll.forEach((t, i) => { %>

                        <tr class="row-data border-bottom"
                            data-index="<%= i %>">

                            <td>
                                <%= t.tgl %>
                            </td>

                            <td>

                                <div class="fw-bold text-uppercase">
                                    <%= t.kat %>
                                </div>

                                <div class="text-muted"
                                    style="font-size:.52rem;">

                                    <%= t.ket %>

                                </div>

                            </td>

                            <td class="text-end">

                                <div class="<%= t.tipeMutasi === 'debet' ? 'text-debet' : 'text-kredit' %>">

                                    <%= t.mutasi %>

                                </div>

                                <div style="font-size:.5rem;">

                                    Sisa:
                                    <%= t.saldo %>

                                </div>

                            </td>

                            <td class="text-center">

                                <% if(t.bukti) { %>

                                <a href="<%= t.bukti %>"
                                    target="_blank"
                                    class="btn-bukti">

                                    LIHAT BUKTI

                                </a>

                                <% } else { %>

                                -

                                <% } %>

                            </td>

                        </tr>

                        <% })} %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

<div id="packaging" class="content-section active">

    <div class="text-center mb-3">
        <small class="text-muted fw-bold">
            Last Updated:
            <%= typeof lastUpdatePack !== 'undefined' ? lastUpdatePack : '-' %>
        </small>
    </div>

    <div class="row g-3">

        <!-- KIRI -->
        <div class="col-lg-8">

            <div class="card-main p-3">

                <h6 class="fw-bold mb-3">
                    STOK KEMASAN
                </h6>

<%
if (typeof packagingAll !== 'undefined' && packagingAll) {

    packagingAll.forEach(p => {

        let isi = '';

        p.listVarian.forEach((val, i) => {

            let ukuran = packHeaders[i];

            if(
                val &&
                val.toString().trim() !== '-' &&
                val.toString().trim() !== ''
            ){

                let kelas = 'stok-ijo';

                let strVal = val.toString().trim();

                let parseVal = strVal
                    .replace(/½/g, '.5')
                    .replace(/¼/g, '.25')
                    .replace(/¾/g, '.75');

                let cleanVal =
                    parseVal.replace(/[^0-9.]/g, '');

                let angka =
                    parseFloat(cleanVal);

                if (!isNaN(angka)) {

                    if (angka <= 2.5) {

                        kelas = 'stok-merah';

                    } else if (angka <= 3) {

                        kelas = 'stok-kuning';
                    }
                }

                isi += `
                    <div class="${kelas}"
                        style="
                            margin:3px 0;
                            padding:5px 8px;
                            border-radius:7px;
                            display:inline-block;
                            font-size:.62rem;
                            min-width:140px;
                        ">

                        ${val} (${ukuran})

                    </div>
                `;
            }

        });
%>

<div class="border rounded p-3 mb-3 bg-white">

    <div class="fw-bold text-uppercase mb-2"
        style="font-size:.72rem;">

        <%= p.nama %>

    </div>

    <div class="d-flex flex-wrap gap-2">

        <%- isi %>

    </div>

</div>

<%
    });
}
%>

            </div>

        </div>

        <!-- KANAN -->
        <div class="col-lg-4">

            <div class="card-main p-3">

                <h6 class="fw-bold text-danger mb-3">
                    ⚠ LOW STOCK
                </h6>

<%
if (typeof packagingAll !== 'undefined' && packagingAll) {

    packagingAll.forEach(p => {

        p.listVarian.forEach((val, i) => {

            let ukuran = packHeaders[i];

            if(
                val &&
                val.toString().trim() !== '-' &&
                val.toString().trim() !== ''
            ){

                let strVal = val.toString().trim();

                let parseVal = strVal
                    .replace(/½/g, '.5')
                    .replace(/¼/g, '.25')
                    .replace(/¾/g, '.75');

                let cleanVal =
                    parseVal.replace(/[^0-9.]/g, '');

                let angka =
                    parseFloat(cleanVal);

                if (!isNaN(angka) && angka <= 3) {
%>

<div class="border rounded p-2 mb-2 bg-light">

    <div class="fw-bold text-uppercase"
        style="font-size:.63rem;">

        <%= p.nama %>

    </div>

    <div class="text-danger fw-bold"
        style="font-size:.6rem;">

        <%= val %> (<%= ukuran %>)

    </div>

</div>

<%
                }
            }

        });

    });

}
%>

            </div>

        </div>

    </div>

</div>
<script>


function openMenu(id, el){

    document.querySelectorAll('.content-section')
        .forEach(s => s.classList.remove('active'));

    document.querySelectorAll('.nav-link')
        .forEach(l => l.classList.remove('active'));

    document.getElementById(id)
        .classList.add('active');

    el.classList.add('active');
}

/* DEFAULT TAMPIL 10 DATA TERAKHIR */
function showDefault(tableId){

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    rows.forEach((row, i) => {

        row.style.display =
            (i < rows.length - 10)
            ? "none"
            : "";
    });
}

/* TOGGLE LIHAT SEMUA */
function toggleFull(tableId, btn){

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    if(rows.length === 0) return;

    const hidden =
        rows[0].style.display === "none";

    const filterShip =
        document.getElementById('filterShip');

    const filterKas =
        document.getElementById('filterKas');

    if(hidden){

        rows.forEach(r => r.style.display = "");

        btn.innerText = "- SEMBUNYIKAN";

        /* MUNCULKAN FILTER */
        if(tableId === 'tableShip' && filterShip){
            filterShip.style.display = 'block';
        }

        if(tableId === 'tableKas' && filterKas){
            filterKas.style.display = 'block';
        }

    } else {

        showDefault(tableId);

        btn.innerText =
            "+ FILTER & LIHAT SEMUA";

        /* SEMBUNYIKAN FILTER */
        if(tableId === 'tableShip' && filterShip){
            filterShip.style.display = 'none';
        }

        if(tableId === 'tableKas' && filterKas){
            filterKas.style.display = 'none';
        }

        /* RESET FILTER */
        if(document.getElementById('sM')){
            document.getElementById('sM').value = "";
        }

        if(document.getElementById('sY')){
            document.getElementById('sY').value = "";
        }

        if(document.getElementById('kM')){
            document.getElementById('kM').value = "";
        }

        if(document.getElementById('kY')){
            document.getElementById('kY').value = "";
        }
    }
}

/* FILTER BULAN & TAHUN */
function filterData(tableId, monthId, yearId){

    const month =
        document.getElementById(monthId).value;

    const year =
        document.getElementById(yearId).value;

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    rows.forEach(row => {

        const text =
            row.innerText;

        const cocokBulan =
            !month || text.includes(month);

        const cocokTahun =
            !year || text.includes(year);

        row.style.display =
            (cocokBulan && cocokTahun)
            ? ""
            : "none";
    });
}

/* EFEK KLIK STOK PRODUK */
document.querySelectorAll('#stocks tbody tr')
.forEach(row => {

    row.addEventListener('click', () => {

        document.querySelectorAll('#stocks tbody tr')
            .forEach(r => r.classList.remove('selected'));

        row.classList.add('selected');

    });

});

/* LOAD AWAL */
window.onload = () => {

    showDefault('tableShip');

    showDefault('tableKas');

}

</script>
</body>
</html>
