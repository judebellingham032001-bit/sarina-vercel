<style>
    /* Tambahkan ke dalam tag <style> di head */
    .stok-merah { background-color: #fee2e2 !important; color: #dc2626 !important; font-weight: 800; }
    .stok-kuning { background-color: #fef3c7 !important; color: #d97706 !important; font-weight: 800; }
    .stok-kuning-keras { background-color: #fde68a !important; color: #92400e !important; font-weight: 800; }
    .stok-ijo { background-color: #dcfce7 !important; color: #16a34a !important; font-weight: 800; }
</style>

<div id="packaging" class="content-section active">
    <div class="card-main">
        <div class="table-responsive">
            <table class="table table-bordered table-sm text-center mb-0">
                <thead class="head-pack">
                    <tr>
                        <th class="ps-3 text-start">PRODUCT</th>
                        <% if (typeof packHeaders !== 'undefined') { packHeaders.forEach(h => { %><th><%= h %></th><% }) } %>
                    </tr>
                </thead>
                <tbody style="font-size: 0.7rem;">
                    <% if (typeof packagingAll !== 'undefined') { packagingAll.forEach(p => { %>
                        <tr class="border-bottom">
                            <td class="ps-3 py-2.5 text-start fw-bold text-uppercase text-secondary"><%= p.nama %></td>
                            <% p.listVarian.forEach(val => { 
                                // LOGIKA WARNA OTOMATIS
                                let kelas = 'stok-ijo';
                                let angka = parseInt(val);
                                if (angka === 0) kelas = 'stok-merah';
                                else if (angka <= 2) kelas = 'stok-kuning';
                                else if (angka === 3) kelas = 'stok-kuning-keras';
                            %>
                                <td class="<%= kelas %>"><%= val %></td>
                            <% }) %>
                        </tr>
                    <% }) } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
