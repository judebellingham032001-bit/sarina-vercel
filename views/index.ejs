<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

body{
    background:#f1f5f9;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding-bottom:30px;
    font-size:.82rem;
}

.container{
    max-width:900px;
    padding:6px;
}

/* NAVIGATION */
.nav-custom{
    background:white;
    border-radius:50px;
    padding:3px;
    border:1px solid #e2e8f0;
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    width:100%;
    justify-content:center;
    gap:2px;
}

.nav-custom::-webkit-scrollbar{
    display:none;
}

.nav-link{
    border-radius:50px;
    color:#64748b;
    font-weight:700;
    padding:5px 9px;
    font-size:.58rem;
    border:none;
    white-space:nowrap;
    flex-shrink:0;
}

.nav-link.active{
    background:#2563eb !important;
    color:white !important;
}

/* CARD */
.card-main{
    background:white;
    border-radius:12px;
    box-shadow:0 1px 3px rgba(0,0,0,.05);
    margin-bottom:12px;
    overflow:auto;
}

.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* WARNA STOK */
.stok-merah{
    background-color:#fee2e2 !important;
    color:#dc2626 !important;
    font-weight:800;
}

.stok-kuning{
    background-color:#fef3c7 !important;
    color:#d97706 !important;
    font-weight:800;
}

.stok-kuning-keras{
    background-color:#fde68a !important;
    color:#92400e !important;
    font-weight:800;
}

.stok-ijo{
    background-color:#dcfce7 !important;
    color:#16a34a !important;
    font-weight:800;
}

/* HEADER TABLE */
.head-stok th{
    background-color:#003153 !important;
    color:white !important;
}

.head-ship th{
    background-color:#000000 !important;
    color:white !important;
}

.head-kas-dark th{
    background-color:#cbd5e1 !important;
    color:#1e293b !important;
}

/* FREEZE HEADER PACKAGING */
.head-pack th{
    background-color:#003153 !important;
    color:white !important;
    position:sticky;
    top:0;
    z-index:10;
}

/* FREEZE KOLOM PERTAMA */
.head-pack th:first-child,
.table td:first-child{
    position:sticky;
    left:0;
    background:white;
    z-index:5;
}

.head-pack th:first-child{
    background:#003153 !important;
    z-index:11;
}

/* SALDO */
.bg-normal{
    background:linear-gradient(135deg,#1e293b,#475569);
}

.bg-minus{
    background:#dc2626 !important;
}

/* TABLE */
th{
    font-size:.55rem;
    padding:8px !important;
    text-transform:uppercase;
    white-space:nowrap;
}

td{
    padding:7px !important;
    vertical-align:middle;
    font-size:.62rem;
}

/* BADGE */
.badge-status{
    padding:3px 7px;
    border-radius:50px;
    font-size:.5rem;
    font-weight:800;
    display:inline-block;
}

.bg-out{
    background:#fee2e2;
    color:#dc2626;
}

.bg-low{
    background:#fef3c7;
    color:#d97706;
}

.bg-tersedia{
    background:#dcfce7;
    color:#16a34a;
}

/* KAS */
.text-debet{
    color:#dc2626;
    font-weight:800;
}

.text-kredit{
    color:#16a34a;
    font-weight:800;
}

/* BUTTON */
.btn-bukti{
    background:#2563eb;
    color:white;
    font-size:.5rem;
    font-weight:800;
    padding:4px 6px;
    border-radius:4px;
    text-decoration:none;
}

.filter-box{
    background:#f8fafc;
    padding:10px;
    border-radius:10px;
    margin:10px;
    border:1px solid #e2e8f0;
}

.btn-toggle{
    font-size:.6rem;
    font-weight:700;
    color:#2563eb;
    background:none;
    border:none;
    margin:5px 10px;
    text-decoration:underline;
}

/* LOGO */
.logo-sarina{
    width:65px;
    height:auto;
    margin-bottom:5px;
}

h1{
    font-size:1.2rem !important;
    font-weight:800;
    margin:0;
}

.sub-title{
    font-size:.55rem;
    color:#64748b;
    font-weight:600;
    letter-spacing:1px;
}

/* MOBILE */
@media(max-width:576px){

    body{
        font-size:.75rem;
    }

    td{
        font-size:.58rem;
        padding:6px !important;
    }

    th{
        font-size:.5rem;
        padding:6px !important;
    }

    .nav-link{
        font-size:.52rem;
        padding:4px 7px;
    }

    .logo-sarina{
        width:55px;
    }

    h1{
        font-size:1rem !important;
    }

}
</style>

<!-- ===================== KAS ===================== -->

<div id="kas" class="content-section">

    <div class="card-main">

        <div class="p-4 text-center <%= (typeof isSaldoMinus !== 'undefined' && isSaldoMinus) ? 'bg-minus' : 'bg-normal' %>"
            style="color:white;">

            <small class="fw-bold opacity-75">
                SALDO KAS
            </small>

            <h2 class="fw-bold m-0"
                style="font-size:1.3rem;">

                <%= typeof saldoTotal !== 'undefined' ? saldoTotal : 'Rp 0' %>

            </h2>

        </div>

        <button class="btn-toggle"
            onclick="toggleFull('tableKas', this)">

            + FILTER & LIHAT SEMUA

        </button>

        <div id="filterKas" style="display:none;">

            <div class="filter-box">

                <div class="row g-2">

                    <div class="col-6">

                        <select id="kM"
                            class="form-select form-select-sm"
                            onchange="filterData('tableKas', 'kM', 'kY')">

                            <option value="">Bulan</option>
                            <option value="Jan">Jan</option>
                            <option value="Feb">Feb</option>
                            <option value="Mar">Mar</option>
                            <option value="Apr">Apr</option>
                            <option value="Mei">Mei</option>
                            <option value="Jun">Jun</option>

                        </select>

                    </div>

                    <div class="col-6">

                        <select id="kY"
                            class="form-select form-select-sm"
                            onchange="filterData('tableKas', 'kM', 'kY')">

                            <option value="">Tahun</option>
                            <option value="2025">2025</option>
                            <option value="2026">2026</option>

                        </select>

                    </div>

                </div>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-sm mb-0"
                id="tableKas">

                <thead class="head-kas-dark">

                    <tr>

                        <th class="ps-2">
                            Tanggal
                        </th>

                        <th>
                            Keterangan
                        </th>

                        <th class="text-end">
                            Mutasi
                        </th>

                        <th class="text-center">
                            Bukti
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <% if (typeof kasAll !== 'undefined' && kasAll) {
                        kasAll.forEach((t, i) => { %>

                    <tr class="row-data border-bottom"
                        data-index="<%= i %>">

                        <td class="ps-2">

                            <div style="font-size:.6rem;">
                                <%= t.tgl %>
                            </div>

                        </td>

                        <td>

                            <div class="fw-bold text-uppercase"
                                style="font-size:.6rem;">

                                <%= t.kat %>

                            </div>

                            <div class="text-muted"
                                style="font-size:.52rem;">

                                <%= t.ket %>

                            </div>

                        </td>

                        <td class="text-end">

                            <div class="<%= t.tipeMutasi === 'debet' ? 'text-debet' : 'text-kredit' %>"
                                style="font-size:.68rem;">

                                <%= t.mutasi %>

                            </div>

                            <div style="font-size:.5rem;font-weight:700;">

                                Sisa:
                                <%= t.saldo %>

                            </div>

                        </td>

                        <td class="text-center">

                            <% if(t.bukti) { %>

                                <a href="<%= t.bukti %>"
                                   target="_blank"
                                   class="btn-bukti">

                                   LIHAT

                                </a>

                            <% } else { %>

                                -

                            <% } %>

                        </td>

                    </tr>

                    <% })} %>

                </tbody>

            </table>

        </div>

    </div>

</div>
