<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">

<title>SARINA STORE | OPERASIONAL</title>

<link rel="icon" type="image/png" href="/logo.png?v=1.6">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

body{
    background:
    linear-gradient(rgba(241,245,249,.72), rgba(241,245,249,.72)),
    url('https://img.magnific.com/vektor-premium/clip-art-vektor-gudang-pusat-logistik-dengan-kotak_353502-526.jpg');

    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;
    background-attachment:fixed;

    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding-bottom:30px;
    font-size:.82rem;
}

.container{
    max-width:900px;
    padding:6px;
}

/* NAVIGATION */
.nav-custom{
    background:rgba(255,255,255,.92);
    backdrop-filter:blur(8px);
    border-radius:50px;
    padding:3px;
    border:1px solid #e2e8f0;
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    width:100%;
    justify-content:center;
    gap:2px;
}

.nav-custom::-webkit-scrollbar{
    display:none;
}

.nav-link{
    border-radius:50px;
    color:#64748b;
    font-weight:700;
    padding:5px 9px;
    font-size:.58rem;
    border:none;
    white-space:nowrap;
    flex-shrink:0;
    transition:.15s;
}

.nav-link:hover{
    background:#eff6ff;
    color:#2563eb;
}

.nav-link.active{
    background:#2563eb !important;
    color:white !important;
}

/* CARD */
.card-main{
    background:rgba(255,255,255,.94);
    backdrop-filter:blur(6px);
    border-radius:12px;
    box-shadow:0 1px 6px rgba(0,0,0,.06);
    margin-bottom:12px;
    overflow:hidden;
}

.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* STOK COLOR */
.stok-merah{
    background-color:#fee2e2 !important;
    color:#dc2626 !important;
    font-weight:800;
}

.stok-kuning{
    background-color:#fef3c7 !important;
    color:#d97706 !important;
    font-weight:800;
}

.stok-ijo{
    background-color:#dcfce7 !important;
    color:#16a34a !important;
    font-weight:800;
}

/* TABLE HEAD */
.head-stok th{
    background:#003153 !important;
    color:white !important;
}

.head-ship th{
    background:#000 !important;
    color:white !important;
}

.head-kas-dark th{
    background:#cbd5e1 !important;
    color:#1e293b !important;
}

/* TABLE PACKAGING */
.table-container{
    max-height:500px;
    overflow:auto;
    position:relative;
}

.head-pack th{
    background:#003153 !important;
    color:white !important;
    position:sticky;
    top:0;
    z-index:20;
}

.head-pack th:not(:first-child){
    background:#166534 !important;
    color:white !important;
}

#packaging table td:first-child,
#packaging table th:first-child{
    position:sticky;
    left:0;
    z-index:10;
    border-right:1px solid #dee2e6;
}

#packaging tbody tr:nth-child(odd) td:first-child{
    background:#f8fafc !important;
}

#packaging tbody tr:nth-child(even) td:first-child{
    background:#eef2f7 !important;
}

#packaging table thead th:first-child{
    z-index:30;
}

#packaging tbody tr:hover td{
    background:#f1f5f9;
    transition:.15s;
}

#packaging tbody tr:hover td:first-child{
    background:#dbeafe !important;
}

/* SALDO */
.bg-normal{
    background:linear-gradient(135deg,#1e293b,#475569);
}

.bg-minus{
    background:#dc2626 !important;
}

/* TABLE */
th{
    font-size:.55rem;
    padding:8px !important;
    text-transform:uppercase;
    white-space:nowrap;
}

td{
    padding:7px !important;
    vertical-align:middle;
    font-size:.62rem;
}

/* BADGE */
.badge-status{
    padding:3px 7px;
    border-radius:50px;
    font-size:.5rem;
    font-weight:800;
    display:inline-block;
}

.bg-out{
    background:#fee2e2;
    color:#dc2626;
}

.bg-low{
    background:#fef3c7;
    color:#d97706;
}

.bg-tersedia{
    background:#dcfce7;
    color:#16a34a;
}

/* HOVER STOK */
#stocks tbody tr{
    transition:.15s;
    cursor:pointer;
}

#stocks tbody tr:hover td{
    background:#eff6ff !important;
}

#stocks tbody tr:active td{
    background:#dbeafe !important;
}

/* TEXT */
.text-debet{
    color:#dc2626;
    font-weight:800;
}

.text-kredit{
    color:#16a34a;
    font-weight:800;
}

/* BUTTON */
.btn-bukti{
    background:#2563eb;
    color:white;
    font-size:.5rem;
    font-weight:800;
    padding:4px 6px;
    border-radius:4px;
    text-decoration:none;
}

.filter-box{
    background:#f8fafc;
    padding:10px;
    border-radius:10px;
    margin:10px;
    border:1px solid #e2e8f0;
}

.btn-toggle{
    font-size:.6rem;
    font-weight:700;
    color:#2563eb;
    background:none;
    border:none;
    margin:5px 10px;
    text-decoration:underline;
}

/* LOGO */
.logo-sarina{
    width:65px;
    height:auto;
    margin-bottom:5px;
}

h1{
    font-size:1.2rem !important;
    font-weight:800;
    margin:0;
}

.sub-title{
    font-size:.55rem;
    color:#64748b;
    font-weight:600;
    letter-spacing:1px;
}

/* MOBILE */
@media(max-width:576px){

    body{
        background-size:cover;
        background-position:center;
        background-attachment:scroll;
        font-size:.75rem;
    }

    td{
        font-size:.58rem;
        padding:6px !important;
    }

    th{
        font-size:.5rem;
        padding:6px !important;
    }

    .nav-link{
        font-size:.52rem;
        padding:4px 7px;
    }

    .logo-sarina{
        width:55px;
    }

    h1{
        font-size:1rem !important;
    }
}

</style>
</head>

<body>

<div class="container">

    <div class="text-center py-3">

        <img src="/logo.png"
             alt="Logo Sarina"
             class="logo-sarina">

        <h1>SARINA STORE</h1>

        <p class="sub-title">
            MANAJEMEN OPERASIONAL
        </p>

        <ul class="nav nav-pills nav-custom mt-2">

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('stocks', this)">
                    STOK PRODUK
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('shipping', this)">
                    PENGIRIMAN
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('kas', this)">
                    KAS
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link active"
                    onclick="openMenu('packaging', this)">
                    STOK KEMASAN
                </button>
            </li>

        </ul>

    </div>

<script>

function openMenu(id, el){

    document.querySelectorAll('.content-section')
        .forEach(s => s.classList.remove('active'));

    document.querySelectorAll('.nav-link')
        .forEach(l => l.classList.remove('active'));

    document.getElementById(id)
        .classList.add('active');

    el.classList.add('active');
}

/* SHOW / HIDE TABLE */
function toggleFull(tableId, btn){

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    const hidden =
        rows[0].style.display === "none";

    const filterShip =
        document.getElementById('filterShip');

    const filterKas =
        document.getElementById('filterKas');

    if(hidden){

        rows.forEach(r => r.style.display = "");

        btn.innerText = "- SEMBUNYIKAN";

        if(tableId === 'tableShip' && filterShip){
            filterShip.style.display = 'block';
        }

        if(tableId === 'tableKas' && filterKas){
            filterKas.style.display = 'block';
        }

    } else {

        showDefault(tableId);

        btn.innerText =
            "+ FILTER & LIHAT SEMUA";

        if(tableId === 'tableShip' && filterShip){
            filterShip.style.display = 'none';
        }

        if(tableId === 'tableKas' && filterKas){
            filterKas.style.display = 'none';
        }
    }
}

/* DEFAULT SHOW LAST 10 */
function showDefault(tableId){

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    rows.forEach((row, i) => {

        row.style.display =
            (i < rows.length - 10)
            ? "none"
            : "";
    });
}

/* FILTER BULAN & TAHUN */
function filterData(tableId, monthId, yearId){

    const month =
        document.getElementById(monthId).value;

    const year =
        document.getElementById(yearId).value;

    const rows =
        document.querySelectorAll(`#${tableId} .row-data`);

    rows.forEach(row => {

        const text =
            row.innerText;

        const cocokBulan =
            !month || text.includes(month);

        const cocokTahun =
            !year || text.includes(year);

        row.style.display =
            (cocokBulan && cocokTahun)
            ? ""
            : "none";
    });
}

/* HOVER / TOUCH STOK */
document.querySelectorAll('#stocks tbody tr').forEach(row => {

    row.addEventListener('click', () => {

        document.querySelectorAll('#stocks tbody tr')
            .forEach(r => r.classList.remove('selected'));

        row.classList.add('selected');

    });

});

/* LOAD */
window.onload = () => {

    showDefault('tableShip');
    showDefault('tableKas');

}

</script>

</body>
</html>
