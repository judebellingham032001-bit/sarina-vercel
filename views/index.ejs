<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">

<title>SARINA STORE | OPERASIONAL</title>

<link rel="icon" type="image/png" href="/logo.png?v=1.6">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

body{
    background:#f1f5f9;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding-bottom:30px;
    font-size:.82rem;
}

.container{
    max-width:900px;
    padding:6px;
}

/* NAV */
.nav-custom{
    background:white;
    border-radius:50px;
    padding:3px;
    border:1px solid #e2e8f0;
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    width:100%;
    justify-content:center;
    gap:2px;
}

.nav-custom::-webkit-scrollbar{
    display:none;
}

.nav-link{
    border-radius:50px;
    color:#64748b;
    font-weight:700;
    padding:5px 9px;
    font-size:.58rem;
    border:none;
    white-space:nowrap;
    flex-shrink:0;
}

.nav-link.active{
    background:#2563eb !important;
    color:white !important;
}

/* CARD */
.card-main{
    background:white;
    border-radius:12px;
    box-shadow:0 1px 3px rgba(0,0,0,.05);
    margin-bottom:12px;
    overflow:hidden;
}

.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* TABLE */
th{
    font-size:.55rem;
    padding:8px !important;
    text-transform:uppercase;
    white-space:nowrap;
}

td{
    padding:7px !important;
    vertical-align:middle;
    font-size:.62rem;
}

/* TABLE HEADER */
.head-stok th{
    background:#003153 !important;
    color:white !important;
}

.head-ship th{
    background:#000 !important;
    color:white !important;
}

.head-kas-dark th{
    background:#cbd5e1 !important;
    color:#1e293b !important;
}

.head-pack th{
    background:#003153 !important;
    color:white !important;
    position:sticky;
    top:0;
    z-index:20;
}

/* PACKAGING FREEZE */
#packaging .table-responsive{
    overflow:auto;
    max-height:75vh;
}

#packaging table th:first-child,
#packaging table td:first-child{
    position:sticky;
    left:0;
    min-width:130px;
    background:white;
    z-index:15;
    box-shadow:2px 0 4px rgba(0,0,0,.05);
}

#packaging table th:first-child{
    background:#003153 !important;
    color:white !important;
    z-index:30;
}

#packaging table th:nth-child(2),
#packaging table td:nth-child(2){
    position:sticky;
    left:130px;
    min-width:80px;
    background:white;
    z-index:14;
    box-shadow:2px 0 4px rgba(0,0,0,.05);
}

#packaging table th:nth-child(2){
    background:#003153 !important;
    color:white !important;
    z-index:29;
}

/* STOCK COLOR */
.stok-merah{
    background:#fee2e2 !important;
    color:#dc2626 !important;
    font-weight:800;
}

.stok-kuning{
    background:#fef3c7 !important;
    color:#d97706 !important;
    font-weight:800;
}

.stok-kuning-keras{
    background:#fde68a !important;
    color:#92400e !important;
    font-weight:800;
}

.stok-ijo{
    background:#dcfce7 !important;
    color:#16a34a !important;
    font-weight:800;
}

/* BADGE */
.badge-status{
    padding:3px 7px;
    border-radius:50px;
    font-size:.5rem;
    font-weight:800;
    display:inline-block;
}

.bg-out{
    background:#fee2e2;
    color:#dc2626;
}

.bg-low{
    background:#fef3c7;
    color:#d97706;
}

.bg-tersedia{
    background:#dcfce7;
    color:#16a34a;
}

/* TEXT */
.text-debet{
    color:#dc2626;
    font-weight:800;
}

.text-kredit{
    color:#16a34a;
    font-weight:800;
}

/* SALDO */
.bg-normal{
    background:linear-gradient(135deg,#1e293b,#475569);
}

.bg-minus{
    background:#dc2626 !important;
}

/* BUTTON */
.btn-bukti{
    background:#2563eb;
    color:white;
    font-size:.5rem;
    font-weight:800;
    padding:4px 6px;
    border-radius:4px;
    text-decoration:none;
}

.btn-toggle{
    font-size:.6rem;
    font-weight:700;
    color:#2563eb;
    background:none;
    border:none;
    margin:5px 10px;
    text-decoration:underline;
}

/* LOGO */
.logo-sarina{
    width:65px;
    margin-bottom:5px;
}

h1{
    font-size:1.2rem !important;
    font-weight:800;
    margin:0;
}

.sub-title{
    font-size:.55rem;
    color:#64748b;
    font-weight:600;
    letter-spacing:1px;
}

/* MOBILE */
@media(max-width:576px){

    td{
        font-size:.58rem;
        padding:6px !important;
    }

    th{
        font-size:.5rem;
        padding:6px !important;
    }

    .nav-link{
        font-size:.52rem;
        padding:4px 7px;
    }

    .logo-sarina{
        width:55px;
    }

    h1{
        font-size:1rem !important;
    }

    #packaging table th:first-child,
    #packaging table td:first-child{
        min-width:110px;
    }

    #packaging table th:nth-child(2),
    #packaging table td:nth-child(2){
        left:110px;
        min-width:70px;
    }

}

</style>
</head>

<body>

<div class="container">

    <div class="text-center py-3">

        <img src="/logo.png"
             alt="Logo Sarina"
             class="logo-sarina">

        <h1>SARINA STORE</h1>

        <p class="sub-title">
            MANAJEMEN OPERASIONAL
        </p>

        <ul class="nav nav-pills nav-custom mt-2">

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('stocks', this)">
                    STOK PRODUK
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('shipping', this)">
                    PENGIRIMAN
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    onclick="openMenu('kas', this)">
                    KAS
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link active"
                    onclick="openMenu('packaging', this)">
                    STOK KEMASAN
                </button>
            </li>

        </ul>

    </div>

    <!-- PACKAGING -->
    <div id="packaging"
         class="content-section active">

        <div class="text-center mb-3">

            <small class="text-muted fw-bold">

                LAST UPDATED:
                <%= typeof lastUpdatePack !== 'undefined'
                    ? lastUpdatePack
                    : '-' %>

            </small>

        </div>

        <div class="card-main">

            <div class="table-responsive">

                <table class="table table-bordered table-sm text-center mb-0">

                    <thead class="head-pack">

                        <tr>

                            <th class="text-start ps-3">
                                PRODUCT
                            </th>

                            <th>
                                GRAMASI
                            </th>

                            <% if(typeof packHeaders !== 'undefined'){
                                packHeaders.forEach(h => { %>

                                <th><%= h %></th>

                            <% }) } %>

                        </tr>

                    </thead>

                    <tbody style="font-size:.65rem;">

                        <% if(typeof packagingAll !== 'undefined'){
                            packagingAll.forEach(p => { %>

                        <tr class="border-bottom">

                            <td class="text-start ps-3 fw-bold text-uppercase text-secondary">

                                <%= p.nama %>

                            </td>

                            <td class="fw-bold">

                                <%= p.gramasi || '-' %>

                            </td>

                            <% p.listVarian.forEach(val => {

                                let angka =
                                    parseInt(
                                        val.replace(/\D/g, '')
                                    ) || 0;

                                let kelas = 'stok-ijo';

                                if(angka === 0)
                                    kelas = 'stok-merah';

                                else if(angka <= 2)
                                    kelas = 'stok-kuning';

                                else if(angka === 3)
                                    kelas = 'stok-kuning-keras';

                            %>

                            <td class="<%= kelas %>">

                                <%= val %>

                            </td>

                            <% }) %>

                        </tr>

                        <% }) } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script>

function openMenu(id, el){

    document.querySelectorAll('.content-section')
        .forEach(s => s.classList.remove('active'));

    document.querySelectorAll('.nav-link')
        .forEach(l => l.classList.remove('active'));

    document.getElementById(id)
        .classList.add('active');

    el.classList.add('active');
}

</script>

</body>
</html>
